    def lr_strategy(self) -> ILRStrategy: ...
    @property
    def gradient_clipper(self) -> IGradientClipper: ...
    @property
    def early_stopper(self) -> IEarlyStopper: ...
    @property
    def observers(self) -> list[ITrainingObserver]: ...
    @property
    def persistence(self) -> IModelPersistence: ...
    @property
    def similarity_metric(self) -> ISimilarityMetric: ...
    @property
    def clusterer(self) -> IClusteringStrategy: ...
    @property
    def oov_factory(self) -> OOVStrategyFactory: ...
    @property
    def anchor_profiler(self) -> IAnchorProfiler: ...
    @property
    def stock_profiler(self) -> IStockProfiler: ...
    @property
    def comparator(self) -> IStockComparator: ...
    @property
    def portfolio_analyser(self) -> IPortfolioAnalyser: ...
    @property
    def searcher(self) -> ISimilaritySearcher: ...
    @property
    def cross_market_searcher(self) -> ICrossMarketSearcher: ...
