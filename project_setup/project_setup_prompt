  config/settings.py reads environment variables
  STOCK2VEC_ENV development or production
  STOCK2VEC_DATA_DIR default data/
  STOCK2VEC_LOG_LEVEL default DEBUG
  STOCK2VEC_PORT default 8050
  AWS_REGION default ap-southeast-2
  S3_BACKUP_BUCKET default empty string

  settings = Settings() module level singleton
  all src/ files import from config.settings
