  class IPriceSource(ABC):
    @abstractmethod
    def fetch(self, tickers: list[str],
              start: str, end: str) -> pd.DataFrame:
      """Fetch OHLCV prices. Returns DataFrame with tickers as columns
         date as index. Missing tickers silently omitted not raised."""

  class ICache(ABC):
    @abstractmethod
    def read(self, key: str) -> pd.DataFrame | None: ...
    @abstractmethod
    def write(self, key: str, df: pd.DataFrame) -> None: ...
    @abstractmethod
    def exists(self, key: str) -> bool: ...
    @abstractmethod
    def get_last_date(self, key: str) -> date | None: ...

  class IDataCleaner(ABC):
    @abstractmethod
    def clean(self, prices: pd.DataFrame) -> pd.DataFrame:
      """Returns cleaned prices. Never raises on individual ticker
         issues. Logs warnings for anomalies."""

  class IReturnsProcessor(ABC):
    @abstractmethod
    def compute(self, prices: pd.DataFrame) -> pd.DataFrame:
      """Returns log returns DataFrame same shape minus first row."""

  class IThresholdStrategy(ABC):
    @abstractmethod
    def compute(self, returns: pd.DataFrame) -> float:
      """Returns co-movement threshold as positive float."""

  class IPairGenerator(ABC):
    @abstractmethod
    def generate(self, returns: pd.DataFrame,
                 t2i: dict[str, int],
                 threshold: float) -> list[tuple[int, int]]:
      """Returns list of (center_idx, target_idx) integer tuples.
         All pairs are bidirectional. Capped per day."""

src/interfaces/model.py

  class IEmbeddingModel(ABC):
    @abstractmethod
    def initialise(self, vocab_size: int,
                   embed_dim: int, seed: int) -> None: ...
    @abstractmethod
    def forward(self, center_idx: int
                ) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
      """Returns (h, scores, probs)."""
    @abstractmethod
    def backward(self, h: np.ndarray, probs: np.ndarray,
                 target_idx: int
                 ) -> tuple[np.ndarray, np.ndarray]:
      """Returns (dW2, dh).
         CRITICAL: uses probs[target_idx] -= 1 never = -1"""
    @abstractmethod
    def update(self, center_idx: int, dW2: np.ndarray,
               dh: np.ndarray, lr: float) -> None: ...
    @abstractmethod
    def get_embeddings(self) -> np.ndarray: ...

  class ITrainingObserver(ABC):
    @abstractmethod
    def on_epoch_start(self, epoch: int) -> None: ...
    @abstractmethod
    def on_epoch_end(self, epoch: int, avg_loss: float) -> None: ...
    @abstractmethod
    def on_training_complete(self, final_loss: float) -> None: ...
    @abstractmethod
    def on_checkpoint(self, epoch: int,
                      W1: np.ndarray) -> None: ...
    @abstractmethod
    def on_error(self, error: Exception) -> None: ...

  class ILRStrategy(ABC):
    @abstractmethod
    def select(self, model: IEmbeddingModel,
               pairs: list[tuple[int, int]]) -> float: ...

  class IGradientClipper(ABC):
    @abstractmethod
    def clip(self, gradient: np.ndarray) -> np.ndarray: ...

  class IEarlyStopper(ABC):
    @abstractmethod
    def should_stop(self,
                    loss_history: list[float]) -> bool: ...

  class IModelPersistence(ABC):
    @abstractmethod
    def save(self, model: IEmbeddingModel,
             vocab: dict, metadata: dict,
             path: Path) -> None: ...
    @abstractmethod
    def load(self, path: Path
             ) -> tuple[np.ndarray, dict, dict]: ...

