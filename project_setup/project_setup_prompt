  class ServiceContainer:
    """Single place where all implementations are wired.
    Changing an implementation means changing this file only.
    All other code depends on interfaces."""

    def __init__(self, settings: Settings):
      self._settings = settings

      # data layer
      self._price_source = YFinancePriceSource(settings)
      self._cache        = ParquetCache(settings.raw_dir)
      self._cleaner      = StandardCleaner(settings)
      self._log_returns  = LogReturnsProcessor()
      self._weekly       = WeeklyResampleProcessor(
                             self._log_returns)
      self._threshold    = VolatilityThresholdStrategy(settings)
      self._pair_gen     = CoMovementPairGenerator(settings)
      self._downloader   = IncrementalDownloader(
                             self._price_source,
                             self._cache)

      # training layer
      self._lr_strategy  = ScanLRStrategy(settings)
      self._clipper      = GradientClipper(settings)
      self._stopper      = PatienceEarlyStopper(settings)
      self._persistence  = NumpyPersistence()
      self._observers    = [
        LossCsvObserver(settings),
        StatusFileObserver(settings),
        CheckpointObserver(settings),
        DashboardNotifierObserver(settings),
      ]

      # embedding layer
      self._metric       = CosineMetric()
      self._clusterer    = GreedyClusterer()
      self._oov_factory  = OOVStrategyFactory()
      self._profiler     = EtfAnchorProfiler()

      # query layer
      self._stock_profiler = EmbeddingStockProfiler(
                               self._metric,
                               self._profiler,
                               self._oov_factory)
      self._comparator   = EmbeddingComparator(
                               self._metric,
                               self._profiler)
      self._port_analyser = PortfolioAnalyser(self._metric)
      self._searcher      = CosineSimilaritySearcher(
                               self._metric)
      self._cross_market  = GlobalModelCrossMarketSearcher(
                               self._metric)
      self._formatter     = ResultFormatter()

    # expose interfaces only never concrete types

    @property
    def downloader(self) -> IncrementalDownloader: ...
    @property
    def cleaner(self) -> IDataCleaner: ...
    @property
    def returns_processor(self) -> IReturnsProcessor: ...
    @property
    def weekly_processor(self) -> IReturnsProcessor: ...
    @property
    def threshold_strategy(self) -> IThresholdStrategy: ...
    @property
    def pair_generator(self) -> IPairGenerator: ...
