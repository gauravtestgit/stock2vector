# Stock2Vec Environment Configuration
# Copy to .env and fill in values

# Environment: development or production
STOCK2VEC_ENV=development

# Data directory (all cached prices, models, logs)
STOCK2VEC_DATA_DIR=data

# Logging level: DEBUG, INFO, WARNING, ERROR
STOCK2VEC_LOG_LEVEL=DEBUG

# Dashboard port
STOCK2VEC_PORT=8050

# AWS region for S3 backup
AWS_REGION=ap-southeast-2

# S3 bucket for model backups (empty string skips backup silently)
S3_BACKUP_BUCKET=
